#!/bin/sh
#
# Pre-commit guard for the Sales Dashboard.
# Blocks any attempt to commit real business / customer data so PII never
# reaches GitHub — including the dangerous `git add -f <ignored file>` case
# that .gitignore alone does NOT stop.
#
# Install once per clone (from the Sales Dashboard folder):
#     git config core.hooksPath githooks
#
# To bypass intentionally (you almost never should):
#     git commit --no-verify

# Staged files being added/copied/modified (NUL-delimited for safe filenames).
staged=$(git diff --cached --name-only --diff-filter=ACM)

# Reject: anything under database/, or any data-file extension.
blocked=$(printf '%s\n' "$staged" | grep -Ei \
    '(^|/)database/|\.(parquet|xlsx|xls|csv|db|sqlite|sqlite3)$')

if [ -n "$blocked" ]; then
    echo "=============================================================="
    echo " COMMIT BLOCKED — data files must never be committed."
    echo " These staged paths look like business/customer data:"
    echo "--------------------------------------------------------------"
    printf '   %s\n' $blocked
    echo "--------------------------------------------------------------"
    echo " Unstage them, e.g.:   git restore --staged <file>"
    echo " They belong only on the local drive, not on GitHub."
    echo "=============================================================="
    exit 1
fi

exit 0
